---
import Deco from './Deco.astro';

const phrases = [
  'ぽちぽち埋めて、ポイントゲット',
  'pochi pochi pachi pachi',
  '色を置くだけ、かんたん完成',
  '気づけば夢中、気づけばポイント',
  '毎日のちょこっと癒し',
];
// シームレスループ用に2回ぶん描画
const loop = [...phrases, ...phrases];
---
<div class="catchband" aria-hidden="true">
  <div class="ribbon">
    <div class="marquee">
      <div class="marquee__track">
        {loop.map((p) => (
          <span class="marquee__item">
            {p}
            <Deco type="star" color="var(--banana)" size={22} class="marquee__star" />
          </span>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .catchband {
    position: relative;
    z-index: 3;
    margin-block: clamp(-6px, -1vw, -10px) clamp(20px, 4vw, 40px);
  }
  .ribbon {
    width: 112%;
    margin-left: -6%;
    transform: rotate(-2deg);
    background: linear-gradient(100deg, var(--sky-deep), var(--pink));
    border-block: 3px solid var(--navy-strong);
    box-shadow: var(--shadow-soft);
    padding-block: 14px;
    overflow: hidden;
  }
  .marquee { overflow: hidden; }
  .marquee__track {
    display: flex;
    width: max-content;
    animation: marquee 26s linear infinite;
  }
  .marquee__item {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    padding-inline: 18px;
    font-family: var(--font-display);
    font-size: clamp(1rem, 3vw, 1.5rem);
    color: #fff;
    white-space: nowrap;
    text-shadow: 0 2px 0 rgba(32, 32, 79, 0.35);
  }
  .marquee__star { flex: none; }

  .ribbon:hover .marquee__track { animation-play-state: paused; }

  @media (prefers-reduced-motion: reduce) {
    .marquee__track { animation: none; transform: translateX(-12%); }
  }
</style>
