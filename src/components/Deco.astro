---
// 浮遊する装飾シェイプ（星・きらきら・ハート・雲・バナナ・まる）
interface Props {
  type?: 'star' | 'sparkle' | 'heart' | 'cloud' | 'banana' | 'dot';
  color?: string;
  outline?: boolean;
  size?: number | string;
  class?: string;
  style?: string;
}
const {
  type = 'star',
  color = 'var(--banana)',
  outline = true,
  size = 40,
  class: cls = '',
  style = '',
} = Astro.props;

const s = typeof size === 'number' ? `${size}px` : size;
const stroke = outline ? 'var(--navy-strong)' : 'none';
const sw = outline ? 1.6 : 0;
---
<svg
  class={`deco ${cls}`}
  style={`width:${s};height:${s};${style}`}
  viewBox="0 0 24 24"
  xmlns="http://www.w3.org/2000/svg"
  fill={color}
  stroke={stroke}
  stroke-width={sw}
  stroke-linejoin="round"
  aria-hidden="true"
>
  {type === 'star' && (
    <path d="M12 1.8c.5 0 1 .3 1.2.8l2.3 4.8 5.2.7c1.1.1 1.5 1.5.7 2.2l-3.8 3.5 1 5.2c.2 1.1-1 2-2 1.4L12 17.9l-4.6 2.5c-1 .6-2.2-.3-2-1.4l1-5.2-3.8-3.5c-.8-.7-.4-2.1.7-2.2l5.2-.7 2.3-4.8c.2-.5.7-.8 1.2-.8Z" />
  )}
  {type === 'sparkle' && (
    <path d="M12 .8c.4 4.7 1.5 8.9 4.3 10.9-2.8 1.1-3.9 5.3-4.3 11.5-.4-6.2-1.5-10.4-4.3-11.5C10.5 9.7 11.6 5.5 12 .8Z" />
  )}
  {type === 'heart' && (
    <path d="M12 21S3.3 14.8 3.3 8.6C3.3 5.5 5.6 3.2 8.6 3.2c1.8 0 3 .9 3.4 1.8.4-.9 1.6-1.8 3.4-1.8 3 0 5.3 2.3 5.3 5.4C20.7 14.8 12 21 12 21Z" />
  )}
  {type === 'cloud' && (
    <path d="M7 19a4.6 4.6 0 0 1-.9-9.1 5.6 5.6 0 0 1 10.7-1.1A4.2 4.2 0 0 1 17 19Z" />
  )}
  {type === 'banana' && (
    <path d="M4.5 8.2c1-1.6 3.2-1.2 3 .6-.6 5.3 4 9.1 9.6 8.3 1.7-.2 2 1.7.5 2.4-7.3 3.2-15.6-3-13.7-11.3Z" />
  )}
  {type === 'dot' && <circle cx="12" cy="12" r="9" />}
</svg>
